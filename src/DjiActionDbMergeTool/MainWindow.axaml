<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="620" d:DesignHeight="440"
        x:Class="DjiActionDbMergeTool.MainWindow"
        Title="DJI Action DB Merge Tool"
        Width="620" Height="440"
        CanResize="False">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Source -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="Source Database:" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Browse..." Width="80"
                        Margin="8,0,0,0" Click="BrowseSource_Click"/>
                <TextBox x:Name="SourcePathBox" VerticalContentAlignment="Center"/>
            </DockPanel>
        </StackPanel>

        <!-- Target -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <TextBlock Text="Target Database:" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Browse..." Width="80"
                        Margin="8,0,0,0" Click="BrowseTarget_Click"/>
                <TextBox x:Name="TargetPathBox" VerticalContentAlignment="Center"/>
            </DockPanel>
        </StackPanel>

        <!-- Merge button + progress -->
        <StackPanel Grid.Row="2" Margin="0,0,0,8">
            <Button x:Name="MergeButton" Content="Merge" Height="34" FontSize="14"
                    Click="Merge_Click"/>
            <ProgressBar x:Name="ProgressBar" Height="14" Margin="0,8,0,0"
                         Minimum="0" Maximum="100" Value="0"/>
        </StackPanel>

        <!-- Status label -->
        <TextBlock x:Name="StatusLabel" Grid.Row="3" Margin="0,0,0,4"
                   Text="Ready." Foreground="Gray"/>

        <!-- Log -->
        <TextBox x:Name="LogBox" Grid.Row="4"
                 IsReadOnly="True" TextWrapping="Wrap"
                 AcceptsReturn="True"
                 Background="#1E1E1E" Foreground="#DCDCDC" FontFamily="Consolas"
                 FontSize="12" Padding="6"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
    </Grid>
</Window>
